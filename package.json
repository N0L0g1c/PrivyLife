{
  "name": "privylife",
  "version": "1.0.0",
  "description": "Your ultimate privacy hub — pick the right tools and get direct links from one place",
  "author": "N0L0g1c",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/N0L0g1c/PrivyLife.git"
  },
  "homepage": "https://github.com/N0L0g1c/PrivyLife#readme",
  "bugs": {
    "url": "https://github.com/N0L0g1c/PrivyLife/issues"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.privylife.app",
    "productName": "PrivyLife",
    "copyright": "Copyright © 2026 N0L0g1c",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "N0L0g1c",
      "repo": "PrivyLife"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "icon": "build/icon.png",
      "maintainer": "N0L0g1c",
      "synopsis": "Privacy hub for Windows and Linux",
      "description": "Discover, compare, and link to the best privacy-respecting tools from one place."
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.png",
      "uninstallerIcon": "build/icon.png"
    }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
